---
import { en, type Locale } from "../data/i18n";
import { navigation, site } from "../data/site";
import ThemeToggle from "./ThemeToggle.astro";

interface Props { locale?: Locale; languageHref?: string; }

const { locale = "en", languageHref: languageHrefOverride } = Astro.props;
const copy = locale === "zh-CN" ? (await import("../data/i18n")).zhCN : en;
const localizedHref = (href: string) =>
  locale === "zh-CN" ? (href === "/" ? "/zh/" : `/zh${href}`) : href;
const visibleNavigation = navigation.filter((item) => item.available);
const currentPath = Astro.url.pathname;
const normalizePath = (pathname: string) => {
  const withoutIndex = pathname.replace(/\/index(?:\.html)?\/?$/, "/");
  return withoutIndex === "/" ? "/" : withoutIndex.replace(/\/+$/, "");
};
const normalizedCurrentPath = normalizePath(currentPath);
const isCurrentNavigation = (key: string, href: string) => {
  const normalizedHref = normalizePath(href);
  return key === "archive"
    ? normalizedCurrentPath === normalizedHref || normalizedCurrentPath.startsWith(`${normalizedHref}/`)
    : normalizedCurrentPath === normalizedHref;
};
const languageHref = languageHrefOverride ?? (locale === "zh-CN"
  ? (currentPath.replace(/^\/zh(?=\/|$)/, "") || "/")
  : `/zh${currentPath === "/" ? "/" : currentPath}`);
---

<header class="site-header">
  <nav class="site-nav" aria-label={copy.navigation.primaryNavigation}>
    <a class="site-nav__brand" href={localizedHref("/")} aria-label={copy.navigation.brandHome}>
      <span class="site-nav__mark" aria-hidden="true"></span>
      <span>{site.name}</span>
    </a>
    <div class="site-nav__links">
      {
        visibleNavigation.map((item) => {
          const href = localizedHref(item.href);
          return (
            <a href={href} aria-current={isCurrentNavigation(item.key, href) ? "page" : undefined}>
              {copy.navigation[item.key]}
            </a>
          );
        })
      }
      <a class="site-nav__language" href={languageHref} lang={locale === "en" ? "zh-CN" : "en"}>
        {copy.navigation.switchLanguage}
      </a>
    </div>
    <ThemeToggle locale={locale} />
  </nav>
</header>
