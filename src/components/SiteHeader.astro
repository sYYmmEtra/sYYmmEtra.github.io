---
import { en, type Locale } from "../data/i18n";
import { navigation, site } from "../data/site";
import ThemeToggle from "./ThemeToggle.astro";

interface Props { locale?: Locale; languageHref?: string; }

const { locale = "en", languageHref: languageHrefOverride } = Astro.props;
const copy = locale === "zh-CN" ? (await import("../data/i18n")).zhCN : en;
const localizedHref = (href: string) =>
  locale === "zh-CN" ? (href === "/" ? "/zh/" : `/zh${href}`) : href;
const visibleNavigation = navigation.filter((item) => item.available);
const currentPath = Astro.url.pathname;
const normalizePath = (pathname: string) => {
  const withoutIndex = pathname.replace(/\/index(?:\.html)?\/?$/, "/");
  return withoutIndex === "/" ? "/" : withoutIndex.replace(/\/+$/, "");
};
const normalizedCurrentPath = normalizePath(currentPath);
const isCurrentNavigation = (key: string, href: string) => {
  const normalizedHref = normalizePath(href);
  return key === "archive"
    ? normalizedCurrentPath === normalizedHref || normalizedCurrentPath.startsWith(`${normalizedHref}/`)
    : normalizedCurrentPath === normalizedHref;
};
const languageHref = languageHrefOverride ?? (locale === "zh-CN"
  ? (currentPath.replace(/^\/zh(?=\/|$)/, "") || "/")
  : `/zh${currentPath === "/" ? "/" : currentPath}`);
---

<header class="site-header">
  <nav class="site-nav" aria-label={copy.navigation.primaryNavigation}>
    <a class="site-nav__brand" href={localizedHref("/")} aria-label={copy.navigation.brandHome}>
      <span class="site-nav__mark" aria-hidden="true"></span>
      <span>{site.name}</span>
    </a>
    <button
      class="mobile-nav-toggle control"
      type="button"
      aria-label={copy.navigation.openNavigation}
      aria-expanded="false"
      aria-controls="mobile-navigation"
      data-mobile-nav-toggle
    >
      <span aria-hidden="true">☰</span>
    </button>
    <div
      class="site-nav__links"
      id="mobile-navigation"
      aria-label={copy.navigation.primaryNavigation}
      aria-hidden="true"
      hidden
      data-mobile-navigation
    >
      <button class="mobile-nav__close control" type="button" aria-label={copy.navigation.closeNavigation} data-mobile-nav-close>
        <span aria-hidden="true">×</span>
      </button>
      {
        visibleNavigation.map((item) => {
          const href = localizedHref(item.href);
          return (
            <a href={href} aria-current={isCurrentNavigation(item.key, href) ? "page" : undefined}>
              {copy.navigation[item.key]}
            </a>
          );
        })
      }
      <a class="site-nav__language" href={languageHref} lang={locale === "en" ? "zh-CN" : "en"}>
        {copy.navigation.switchLanguage}
      </a>
    </div>
    <ThemeToggle locale={locale} />
    <script is:inline>
      const mobileToggle = document.querySelector("[data-mobile-nav-toggle]");
      const mobileMenu = document.querySelector("[data-mobile-navigation]");
      const mobileClose = document.querySelector("[data-mobile-nav-close]");
      const mobile = window.matchMedia("(max-width: 38rem)");

      const setClosed = (restoreFocus = false) => {
        if (!(mobileToggle instanceof HTMLButtonElement) || !(mobileMenu instanceof HTMLElement)) return;
        mobileMenu.hidden = true;
        mobileMenu.setAttribute("aria-hidden", "true");
        mobileToggle.setAttribute("aria-expanded", "false");
        if (restoreFocus) mobileToggle.focus();
      };
      const setOpen = () => {
        if (!(mobileToggle instanceof HTMLButtonElement) || !(mobileMenu instanceof HTMLElement)) return;
        mobileMenu.hidden = false;
        mobileMenu.setAttribute("aria-hidden", "false");
        mobileToggle.setAttribute("aria-expanded", "true");
        requestAnimationFrame(() => mobileMenu.querySelector("a") instanceof HTMLAnchorElement && mobileMenu.querySelector("a").focus());
      };
      const applyBreakpoint = () => {
        if (!(mobileToggle instanceof HTMLButtonElement) || !(mobileMenu instanceof HTMLElement)) return;
        if (mobile.matches) {
          mobileToggle.hidden = false;
          setClosed();
        } else {
          mobileToggle.hidden = true;
          mobileMenu.hidden = false;
          mobileMenu.removeAttribute("aria-hidden");
          mobileToggle.setAttribute("aria-expanded", "false");
        }
      };

      mobileToggle?.addEventListener("click", () => {
        if (mobileMenu instanceof HTMLElement && mobileMenu.hidden) setOpen();
        else setClosed();
      });
      mobileClose?.addEventListener("click", () => setClosed(true));
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && mobile.matches && mobileMenu instanceof HTMLElement && !mobileMenu.hidden) setClosed(true);
      });
      document.addEventListener("pointerdown", (event) => {
        if (mobile.matches && mobileMenu instanceof HTMLElement && !mobileMenu.hidden && !mobileMenu.contains(event.target) && event.target !== mobileToggle) setClosed();
      });
      mobileMenu?.addEventListener("click", (event) => { if (event.target instanceof HTMLAnchorElement) setClosed(); });
      mobile.addEventListener("change", applyBreakpoint);
      applyBreakpoint();
    </script>
  </nav>
</header>
