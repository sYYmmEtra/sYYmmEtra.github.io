---
import { getCollection } from "astro:content";
import LessonCard from "../../../components/LessonCard.astro";
import LessonFilters from "../../../components/LessonFilters.astro";
import LessonSearch from "../../../components/LessonSearch.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { zhCN } from "../../../data/i18n";

const lessons = (await getCollection("aiDaily")).sort((left, right) =>
  right.data.date.localeCompare(left.data.date) || right.data.lesson - left.data.lesson,
);
---

<BaseLayout locale="zh-CN" title={`${zhCN.archive.title} — sYYmmEtra`} description={zhCN.archive.description}>
  <section class="lesson-archive" aria-labelledby="archive-title">
    <header class="lesson-archive__header"><p class="eyebrow">sYYmmEtra</p><h1 class="display-heading" id="archive-title">{zhCN.archive.title}</h1><p>{zhCN.archive.description}</p></header>
    <LessonSearch locale="zh-CN" />
    <LessonFilters locale="zh-CN" />
    <div class="lesson-archive__list">{lessons.map((lesson) => <LessonCard lesson={lesson} locale="zh-CN" />)}</div>
  </section>
</BaseLayout>
