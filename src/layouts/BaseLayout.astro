---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import Seo from "../components/Seo.astro";
import { en, type Locale } from "../data/i18n";
import { site } from "../data/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
  languageHref?: string;
  canonicalPath?: string;
  alternates?: { en: string; zhCN: string };
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  seoType?: "website" | "article";
}

const {
  title = site.name,
  locale = "en",
  languageHref,
  canonicalPath = Astro.url.pathname,
  alternates,
  structuredData,
  seoType,
} = Astro.props;
const description = Astro.props.description ?? (
  locale === "zh-CN" ? site.descriptionZh : site.description
);
const language = locale === "zh-CN" ? "zh-CN" : "en";
const copy = locale === "zh-CN" ? (await import("../data/i18n")).zhCN : en;
---

<!doctype html>
<html lang={language} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <Seo title={title} description={description} canonicalPath={canonicalPath} locale={locale} alternates={alternates} structuredData={structuredData} type={seoType} />
    <script is:inline>
      (() => {
        const colorScheme = window.matchMedia("(prefers-color-scheme: dark)");
        try {
          const stored = localStorage.getItem("theme");
          const preference = stored === "dark" || stored === "light" || stored === "system"
            ? stored
            : "system";
          document.documentElement.dataset.themePreference = preference;
          document.documentElement.dataset.theme = preference === "system"
            ? colorScheme.matches ? "dark" : "light"
            : preference;
        } catch {
          document.documentElement.dataset.themePreference = "system";
          document.documentElement.dataset.theme = colorScheme.matches ? "dark" : "light";
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">{copy.navigation.skipToContent}</a>
    <SiteHeader locale={locale} languageHref={languageHref} />
    <main class="site-main reading-shell" id="main-content" tabindex="-1">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
